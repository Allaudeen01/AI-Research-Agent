# Copy this file to .env and fill in your API keys

# ── LLM Provider ──────────────────────────────────────────────────────────
# Choose which LLM backend to use: "groq" (default) or "openai"
LLM_PROVIDER=groq

# ── Groq (default — fast & free tier available) ───────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional: override the default Groq model
# openai/gpt-oss-20b  — fastest (1000 tps), cheapest (default)
# openai/gpt-oss-120b — most capable (500 tps), best for complex queries
# GROQ_MODEL=openai/gpt-oss-20b

# ── OpenAI (alternative) ──────────────────────────────────────────────────
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Optional: override the default OpenAI model
# OPENAI_MODEL=gpt-4o-mini

# ── Tavily Search (required for web_search tool) ──────────────────────────
# Get a free key at https://app.tavily.com (1000 searches/month free)
TAVILY_API_KEY=tvly-...
